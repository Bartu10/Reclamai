# ─────────────────────────────────────────────
#  ReclamaAI — Variables de entorno
# ─────────────────────────────────────────────

# Obtén tu API key gratis en: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar (no cambies esto salvo que sepas lo que haces)
# llama-3.1-8b-instant  → más rápido, free tier generoso  ← recomendado
# llama-3.3-70b-versatile → más calidad, consume más cuota
GROQ_MODEL=llama-3.1-8b-instant

# Puerto del servidor (Render lo asigna automáticamente via PORT)
PORT=3000
